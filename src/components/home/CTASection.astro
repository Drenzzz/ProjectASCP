---
import { buttonVariants } from "@/components/ui/button";
---

<section class="py-20">
    <div class="container px-4 mx-auto text-center space-y-8">
        <div class="inline-flex items-center justify-center p-3 rounded-2xl bg-secondary/30 mb-4">
            <svg
                class="h-8 w-8 text-primary"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
            >
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
                <path d="M2 12h20"></path>
            </svg>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">Ready to Upgrade?</h2>
        <p class="text-xl text-muted-foreground max-w-2xl mx-auto">
            Join the community and give your device a new life with ASCP.
        </p>
        <a
            href="/devices"
            class={buttonVariants({
                size: "lg",
                className: "h-12 px-12 text-base font-bold rounded-full",
            })}
        >
            Start Download
        </a>
    </div>
</section>
