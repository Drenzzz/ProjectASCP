---
export interface Props {
    iconPath: string;
    title: string;
    description: string;
}

const { iconPath, title, description } = Astro.props;
---

<div class="p-6 rounded-2xl bg-gradient-to-r from-white/[0.06] to-white/[0.02] border border-white/10 hover:border-primary/40 transition-all duration-300 space-y-4">
    <div class="w-12 h-12 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center">
        <svg
            class="h-6 w-6 text-primary"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
        >
            <Fragment set:html={iconPath} />
        </svg>
    </div>
    <h2 class="text-xl font-bold">{title}</h2>
    <p class="text-muted-foreground leading-relaxed text-sm">{description}</p>
</div>
