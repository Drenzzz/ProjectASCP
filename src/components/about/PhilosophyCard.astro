---
export interface Props {
    iconPath: string;
    title: string;
    description: string;
}

const { iconPath, title, description } = Astro.props;
---

<div class="bento-card p-8 rounded-[32px] bg-[#f0f4f8] hover:bg-[#e4ebf3] hover:scale-[1.01] transition-all duration-300 flex flex-col gap-6 border-0 shadow-none relative overflow-hidden">
    <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary shrink-0 select-none">
        <svg
            class="h-7 w-7 text-primary"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
        >
            <Fragment set:html={iconPath} />
        </svg>
    </div>
    
    <div class="space-y-2">
        <h2 class="text-2xl font-black text-gray-900 tracking-tight leading-none">
            {title}
        </h2>
        <p class="text-base text-gray-600 leading-relaxed font-medium">
            {description}
        </p>
    </div>
</div>
