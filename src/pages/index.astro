---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroSection from "@/components/home/HeroSection.astro";
import FeaturesSection from "@/components/home/FeaturesSection.astro";
import ScreenshotGallery from "@/components/home/ScreenshotGallery.astro";
import StatsSection from "@/components/home/StatsSection.astro";
import { FAQSection } from "@/components/home/FAQSection";
import CTASection from "@/components/home/CTASection.astro";
---

<BaseLayout title="ASCP - AOSP Based Android ROM">
    <HeroSection />
    <FeaturesSection />
    <StatsSection />
    <ScreenshotGallery />
    <FAQSection client:visible />
    <CTASection />
</BaseLayout>
