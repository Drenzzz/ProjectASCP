---
import { cn } from "@/lib/utils";

export interface Props {
    title: string;
    highlight?: string;
    description: string;
    eyebrow?: string;
    class?: string;
}

const { title, highlight, description, eyebrow, class: className = "" } = Astro.props;
---

<section class={cn("py-14 md:py-18 border-b border-gray-200", className)}>
    <div class="container-wide text-center space-y-3">
        {eyebrow && (
            <p class="text-xs font-semibold tracking-widest uppercase text-gray-400">{eyebrow}</p>
        )}
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-gray-900">
            {title}{highlight && <> {highlight}</>}
        </h1>
        <p class="text-base md:text-lg text-gray-500 max-w-xl mx-auto leading-relaxed">{description}</p>
    </div>
</section>

