---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ChangelogTimeline from "@/components/changelog/ChangelogTimeline.astro";
import { changelogData } from "@/data/changelogs";
---

<BaseLayout
    title="Changelog | ASCP"
    description="Stay updated with the latest improvements, fixes, and features of Project ASCP."
>
    <section class="relative w-full h-[50vh] min-h-[400px] flex items-center justify-center overflow-hidden">
        <div
            class="absolute inset-0 bg-cover bg-center bg-no-repeat z-0 scale-105"
            style="background-image: url('/banner.jpg')"
        >
            <div class="absolute inset-0 bg-black/60"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-background via-background/40 to-transparent"></div>
            <div class="absolute inset-0 bg-gradient-to-b from-background/80 via-transparent to-transparent opacity-60"></div>
        </div>

        <div class="relative z-10 container px-4 mx-auto text-center space-y-6 pt-20">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 backdrop-blur-md mb-2">
                <svg
                    class="w-4 h-4 text-primary animate-pulse"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <circle cx="12" cy="12" r="4"></circle>
                    <path d="M12 2v2"></path>
                    <path d="M12 20v2"></path>
                    <path d="m4.93 4.93 1.41 1.41"></path>
                    <path d="m17.66 17.66 1.41 1.41"></path>
                    <path d="M2 12h2"></path>
                    <path d="M20 12h2"></path>
                    <path d="m6.34 17.66-1.41 1.41"></path>
                    <path d="m19.07 4.93-1.41 1.41"></path>
                </svg>
                <span class="text-xs font-medium text-primary tracking-wide uppercase">System Changelog</span>
            </div>

            <h1 class="text-5xl md:text-7xl font-bold tracking-tighter text-white drop-shadow-2xl">
                Evolution of <span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-white to-white/50">ASCP</span>
            </h1>

            <p class="text-lg md:text-xl text-zinc-300 max-w-2xl mx-auto leading-relaxed font-light">
                Track every commit, every fix, and every improvement. <br class="hidden md:block" />
                See how we&apos;re pushing the boundaries of what&apos;s clear.
            </p>

            <div class="pt-8">
                <a
                    href="/"
                    class="inline-flex items-center justify-center rounded-full px-8 py-6 bg-white/5 border border-white/10 text-white hover:bg-white/10 hover:text-white transition-all duration-300 backdrop-blur-sm group text-base font-medium"
                >
                    <svg
                        class="mr-2 h-4 w-4 group-hover:-translate-x-1 transition-transform"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path d="m12 19-7-7 7-7"></path>
                        <path d="M19 12H5"></path>
                    </svg>
                    Back to Home
                </a>
            </div>
        </div>
    </section>

    <div class="relative z-20 container px-4 md:px-6 mx-auto -mt-20 pb-32">
        <ChangelogTimeline data={changelogData} />
    </div>

    <div class="fixed bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-background to-transparent pointer-events-none z-10"></div>
</BaseLayout>
