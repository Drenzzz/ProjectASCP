---
import type { Maintainer } from "@/lib/schema/team";

export interface Props {
    member: Maintainer;
}

const { member } = Astro.props;
---

<div class="bento-card p-6 rounded-[28px] bg-[#f0f4f8] hover:bg-[#e4ebf3] hover:scale-[1.01] transition-all duration-300 flex flex-col justify-between h-full border-0 shadow-none relative overflow-hidden">
    <div class="flex items-start gap-4">
        {/* Avatar Image with rounded-2xl */}
        <div class="shrink-0 w-20 h-20 rounded-[20px] overflow-hidden bg-gray-200 flex items-center justify-center select-none shadow-xs">
            {
                member.avatarUrl ? (
                    <img
                        src={member.avatarUrl}
                        alt={member.name}
                        width="96"
                        height="96"
                        class="object-cover w-full h-full"
                        onerror={`this.src='https://api.dicebear.com/7.x/initials/svg?seed=' + encodeURIComponent('${member.name}')`}
                        loading="lazy"
                    />
                ) : (
                    <svg
                        class="h-8 w-8 text-gray-400"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                )
            }
        </div>

        {/* Member Details */}
        <div class="flex-1 min-w-0 space-y-1">
            <h3 class="font-black text-lg text-gray-900 leading-tight truncate">
                {member.name}
            </h3>
            <p class="text-xs font-extrabold text-primary tracking-wider leading-none">
                {member.role}
            </p>

            {/* Social Icons Row */}
            <div class="flex items-center gap-1.5 pt-2">
                {
                    member.githubUrl && (
                        <a
                            href={member.githubUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex items-center justify-center w-8 h-8 rounded-full bg-white text-gray-500 hover:text-primary hover:bg-primary/10 transition-all select-none border-0 shadow-none cursor-pointer"
                            aria-label={`${member.name}'s GitHub`}
                        >
                            <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24">
                                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                            </svg>
                        </a>
                    )
                }
                {
                    member.telegram && (
                        <a
                            href={`https://t.me/${member.telegram}`}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex items-center justify-center w-8 h-8 rounded-full bg-white text-gray-500 hover:text-primary hover:bg-primary/10 transition-all select-none border-0 shadow-none cursor-pointer"
                            aria-label={`${member.name}'s Telegram`}
                        >
                            <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24">
                                <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.161c-.18.717-.962 4.084-1.362 5.795-.169.724-.436.966-.692.989-1.222.115-2.148-.807-3.332-1.583-1.853-1.215-2.9-1.97-4.697-3.153-2.077-1.368-.731-2.12.454-2.12.31 0 5.617-2.433 5.72-2.868.013-.055.025-.26-.098-.37-.123-.11-.304-.075-.436-.045-.187.042-3.167 2.01-8.941 5.922-.846.58-1.612.866-2.298.85-.756-.017-2.21-.429-3.292-.78-1.328-.431-2.384-.66-2.293-1.393.047-.382.574-.775 1.58-1.18 6.17-2.686 10.283-4.457 12.338-5.313 5.882-2.446 7.103-2.87 7.9-2.884.175-.003.567.04.818.243.212.17.27.4.293.57.023.17.034.492.018.795z"/>
                            </svg>
                        </a>
                    )
                }
                {
                    member.xdaUrl && (
                        <a
                            href={member.xdaUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex items-center justify-center w-8 h-8 rounded-full bg-white text-gray-500 hover:text-primary hover:bg-primary/10 transition-all select-none border-0 shadow-none cursor-pointer"
                            aria-label={`${member.name}'s XDA Profile`}
                        >
                            <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24">
                                <path d="M17.9 17.29c-.36 0-.65-.29-.65-.65v-4.53c0-.36.29-.65.65-.65s.65.29.65.65v4.53c0 .36-.29.65-.65.65zm-11.8 0c-.36 0-.65-.29-.65-.65v-4.53c0-.36.29-.65.65-.65s.65.29.65.65v4.53c0 .36-.29.65-.65.65zm11.23-7.97l1.66-2.88c.12-.22.05-.5-.17-.62a.496.496 0 0 0-.67.17l-1.69 2.93c-1.39-.63-2.97-.98-4.63-.98s-3.24.35-4.63.98L6.48 5.99c-.11-.2-.37-.28-.59-.17-.22.11-.3.37-.19.59l1.66 2.88C4.09 11.16 2 13.9 2 17h20c0-3.1-2.09-5.84-5.37-7.68zM9 13.5c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm6 0c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"/>
                            </svg>
                        </a>
                    )
                }
            </div>
        </div>
    </div>

    {/* Subtle divider */}
    <div class="border-t border-gray-200/60 my-4 w-full"></div>

    {/* Tagline at the bottom */}
    <p class="text-sm font-medium text-gray-600 leading-relaxed italic block mt-auto">
        "{member.tagline || "Code. Build. Repeat."}"
    </p>
</div>
