---
const communityLinks = [
    { href: "https://t.me/ascp_marble", label: "Telegram Group" },
    { href: "https://t.me/ascp_updates", label: "Update Channel" },
];

const navLinks = [
    { href: "/changelog", label: "Changelog" },
    { href: "/about", label: "About" },
];

const sourceLinks = [
    { href: "https://github.com/Pixelify-AOSP", label: "GitHub" },
];
---

<footer class="bg-primary">
    <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-8">
            <div class="md:col-span-1">
                <a href="/" class="flex items-center gap-2 mb-4">
                    <img
                        src="/logo/ASCP-nobg.png"
                        alt="ASCP"
                        width="28"
                        height="28"
                        class="h-7 w-7 brightness-0 invert"
                    />
                    <span class="font-bold text-lg text-white tracking-tight">
                        ASCP
                    </span>
                </a>
                <p class="text-sm text-white/60 mb-1">
                    &copy; 2026 ASCP. All Rights Reserved.
                </p>
                <p class="text-xs text-white/40">
                    Designed by{" "}
                    <a
                        href="https://github.com/Drenzzz"
                        target="_blank"
                        rel="noreferrer"
                        class="text-white/60 hover:text-white transition-colors"
                    >
                        Drenzzz
                    </a>
                </p>
            </div>

            <div>
                <h3 class="text-sm font-semibold text-white mb-4">Community</h3>
                <ul class="space-y-2">
                    {communityLinks.map((link) => (
                        <li>
                            <a
                                href={link.href}
                                target="_blank"
                                rel="noreferrer"
                                class="text-sm text-white/60 hover:text-white transition-colors"
                            >
                                {link.label}
                            </a>
                        </li>
                    ))}
                </ul>
            </div>

            <div>
                <h3 class="text-sm font-semibold text-white mb-4">Links</h3>
                <ul class="space-y-2">
                    {navLinks.map((link) => (
                        <li>
                            <a
                                href={link.href}
                                class="text-sm text-white/60 hover:text-white transition-colors"
                            >
                                {link.label}
                            </a>
                        </li>
                    ))}
                </ul>
            </div>

            <div>
                <h3 class="text-sm font-semibold text-white mb-4">Source code</h3>
                <ul class="space-y-2">
                    {sourceLinks.map((link) => (
                        <li>
                            <a
                                href={link.href}
                                target="_blank"
                                rel="noreferrer"
                                class="text-sm text-white/60 hover:text-white transition-colors"
                            >
                                {link.label}
                            </a>
                        </li>
                    ))}
                </ul>
            </div>
        </div>
    </div>
</footer>
