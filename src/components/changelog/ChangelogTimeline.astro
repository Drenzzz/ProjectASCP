---
import { Badge } from "@/components/ui/badge";
import type { Changelog } from "@/data/changelogs/types";

export interface Props {
    data: Changelog[];
}

const { data } = Astro.props;

const getCategoryIcon = (category: string) => {
    const lower = category.toLowerCase();
    const baseClass = "w-4 h-4";

    if (lower.includes("system") || lower.includes("core")) {
        return (
            <svg class={`${baseClass} text-blue-400`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="4" y="4" width="16" height="16" rx="2"></rect>
                <rect x="9" y="9" width="6" height="6" rx="1"></rect>
                <path d="M15 2v2"></path>
                <path d="M15 20v2"></path>
                <path d="M2 15h2"></path>
                <path d="M2 9h2"></path>
                <path d="M20 15h2"></path>
                <path d="M20 9h2"></path>
                <path d="M9 2v2"></path>
                <path d="M9 20v2"></path>
            </svg>
        );
    }
    if (lower.includes("bug") || lower.includes("fix")) {
        return (
            <svg class={`${baseClass} text-red-400`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m8 2 1.88 1.88"></path>
                <path d="M14.12 3.88 16 2"></path>
                <path d="M19.13 8.74a7.5 7.5 0 0 0-14.26 0"></path>
                <path d="M5.5 8.5h13"></path>
                <path d="M6.5 14v3a1 1 0 0 0 1 1h9a1 1 0 0 0 1-1v-3"></path>
                <path d="M6.5 11.5h11"></path>
                <path d="M3 14h2"></path>
                <path d="M19 14h2"></path>
            </svg>
        );
    }
    if (lower.includes("visual") || lower.includes("ui") || lower.includes("design") || lower.includes("experience") || lower.includes("animation")) {
        return (
            <svg class={`${baseClass} text-purple-400`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="13.5" cy="6.5" r=".5" fill="currentColor"></circle>
                <circle cx="17.5" cy="10.5" r=".5" fill="currentColor"></circle>
                <circle cx="8.5" cy="7.5" r=".5" fill="currentColor"></circle>
                <circle cx="6.5" cy="12.5" r=".5" fill="currentColor"></circle>
                <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"></path>
            </svg>
        );
    }
    if (lower.includes("feature") || lower.includes("addon") || lower.includes("power") || lower.includes("smart")) {
        return (
            <svg class={`${baseClass} text-amber-400`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"></path>
                <path d="M20 3v4"></path>
                <path d="M22 5h-4"></path>
                <path d="M4 17v2"></path>
                <path d="M5 18H3"></path>
            </svg>
        );
    }
    if (lower.includes("improvement") || lower.includes("other")) {
        return (
            <svg class={`${baseClass} text-emerald-400`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"></path>
                <path d="M8.5 2h7"></path>
                <path d="M7 16h10"></path>
            </svg>
        );
    }
    if (lower.includes("privacy") || lower.includes("security")) {
        return (
            <svg class={`${baseClass} text-cyan-400`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
            </svg>
        );
    }
    return (
        <svg class={`${baseClass} text-primary`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="m9 12 2 2 4-4"></path>
        </svg>
    );
};
---

<section class="relative max-w-4xl mx-auto px-4 py-12">
    <div class="absolute left-[28px] md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-primary/20 to-transparent transform -translate-x-1/2"></div>

    <div class="space-y-16">
        {
            data.map((release, index) => (
                <article class="relative flex flex-col md:flex-row gap-8 items-start md:items-center">
                    <div class="absolute left-[28px] md:left-1/2 w-4 h-4 rounded-full bg-background border-2 border-primary shadow-[0_0_10px_var(--primary)] transform -translate-x-1/2 mt-6 z-10 flex items-center justify-center">
                        <div class="w-1.5 h-1.5 rounded-full bg-primary"></div>
                    </div>

                    {index % 2 === 0 ? (
                        <>
                            <div class="w-full md:w-[calc(50%-32px)] pl-16 md:pl-0">
                                <div class="group relative bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-6 hover:border-primary/30 transition-all duration-300 shadow-xl overflow-hidden">
                                    <div class="absolute -top-20 -right-20 w-40 h-40 bg-primary/10 rounded-full blur-3xl group-hover:bg-primary/20 transition-all duration-500"></div>

                                    <div class="relative flex items-start justify-between mb-4 border-b border-white/5 pb-4">
                                        <div>
                                            <div class="flex items-center gap-3 mb-1">
                                                <h2 class="text-2xl font-bold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-white to-white/60">
                                                    {release.version}
                                                </h2>
                                                <Badge
                                                    variant={release.type === "Stable" ? "default" : "secondary"}
                                                    className="h-5 px-2 text-[10px] uppercase tracking-wider"
                                                >
                                                    {release.type}
                                                </Badge>
                                            </div>
                                            <span class="flex items-center gap-1.5 text-xs font-medium text-muted-foreground">
                                                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                                </svg>
                                                {release.date}
                                            </span>
                                        </div>
                                    </div>

                                    <p class="text-sm text-muted-foreground/90 italic mb-6 leading-relaxed relative z-10">
                                        &ldquo;{release.description}&rdquo;
                                    </p>

                                    <div class="space-y-6 relative z-10">
                                        {release.content.map((category) => (
                                            <div>
                                                <h4 class="flex items-center gap-2 text-xs font-bold text-foreground uppercase tracking-widest mb-3 opacity-90">
                                                    {getCategoryIcon(category.name)}
                                                    {category.name}
                                                </h4>
                                                <ul class="space-y-2">
                                                    {category.items.map((item) => (
                                                        <li class="text-sm text-muted-foreground/80 pl-6 relative leading-relaxed hover:text-foreground transition-colors">
                                                            <span class="absolute left-1.5 top-2.5 w-1 h-1 rounded-full bg-white/20"></span>
                                                            {item}
                                                        </li>
                                                    ))}
                                                </ul>
                                            </div>
                                        ))}
                                    </div>

                                    {release.note && (
                                        <div class="mt-6 pt-4 border-t border-white/5">
                                            <div class="bg-primary/5 rounded-lg p-3 border border-primary/10 flex gap-3 items-start">
                                                <svg class="w-4 h-4 text-primary shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                                                    <line x1="7" y1="7" x2="7.01" y2="7"></line>
                                                </svg>
                                                <p class="text-xs text-muted-foreground leading-relaxed">{release.note}</p>
                                            </div>
                                        </div>
                                    )}
                                </div>
                            </div>
                            <div class="hidden md:block w-[calc(50%-32px)]"></div>
                        </>
                    ) : (
                        <>
                            <div class="hidden md:block w-[calc(50%-32px)]"></div>
                            <div class="w-full md:w-[calc(50%-32px)] pl-16 md:pl-0">
                                <div class="group relative bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-6 hover:border-primary/30 transition-all duration-300 shadow-xl overflow-hidden">
                                    <div class="absolute -top-20 -right-20 w-40 h-40 bg-primary/10 rounded-full blur-3xl group-hover:bg-primary/20 transition-all duration-500"></div>

                                    <div class="relative flex items-start justify-between mb-4 border-b border-white/5 pb-4">
                                        <div>
                                            <div class="flex items-center gap-3 mb-1">
                                                <h2 class="text-2xl font-bold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-white to-white/60">
                                                    {release.version}
                                                </h2>
                                                <Badge
                                                    variant={release.type === "Stable" ? "default" : "secondary"}
                                                    className="h-5 px-2 text-[10px] uppercase tracking-wider"
                                                >
                                                    {release.type}
                                                </Badge>
                                            </div>
                                            <span class="flex items-center gap-1.5 text-xs font-medium text-muted-foreground">
                                                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                                </svg>
                                                {release.date}
                                            </span>
                                        </div>
                                    </div>

                                    <p class="text-sm text-muted-foreground/90 italic mb-6 leading-relaxed relative z-10">
                                        &ldquo;{release.description}&rdquo;
                                    </p>

                                    <div class="space-y-6 relative z-10">
                                        {release.content.map((category) => (
                                            <div>
                                                <h4 class="flex items-center gap-2 text-xs font-bold text-foreground uppercase tracking-widest mb-3 opacity-90">
                                                    {getCategoryIcon(category.name)}
                                                    {category.name}
                                                </h4>
                                                <ul class="space-y-2">
                                                    {category.items.map((item) => (
                                                        <li class="text-sm text-muted-foreground/80 pl-6 relative leading-relaxed hover:text-foreground transition-colors">
                                                            <span class="absolute left-1.5 top-2.5 w-1 h-1 rounded-full bg-white/20"></span>
                                                            {item}
                                                        </li>
                                                    ))}
                                                </ul>
                                            </div>
                                        ))}
                                    </div>

                                    {release.note && (
                                        <div class="mt-6 pt-4 border-t border-white/5">
                                            <div class="bg-primary/5 rounded-lg p-3 border border-primary/10 flex gap-3 items-start">
                                                <svg class="w-4 h-4 text-primary shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                                                    <line x1="7" y1="7" x2="7.01" y2="7"></line>
                                                </svg>
                                                <p class="text-xs text-muted-foreground leading-relaxed">{release.note}</p>
                                            </div>
                                        </div>
                                    )}
                                </div>
                            </div>
                        </>
                    )}
                </article>
            ))
        }
    </div>
</section>
