---
import { buttonVariants } from "@/components/ui/button";

const navLinks = [
    { href: "/", label: "Home" },
    { href: "/devices", label: "Devices" },
    { href: "/changelog", label: "Changelog" },
    { href: "/about", label: "About" },
];

const socialLinks = [
    {
        href: "https://github.com/Pixelify-AOSP",
        label: "GitHub",
        icon: `<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />`,
    },
];
---

<footer class="relative border-t border-white/10 backdrop-blur-xl">
    <div class="container mx-auto px-4 py-12 relative">
        <div class="flex flex-col items-center gap-8">
            <div class="flex flex-col md:flex-row items-center gap-6 md:gap-10">
                <a href="/" class="flex items-center gap-3 group">
                    <span class="font-bold text-lg tracking-tight">
                        PROJECT <span class="text-primary">ASCP</span>
                    </span>
                </a>

                <div class="hidden md:block w-px h-6 bg-white/10"></div>

                <nav class="flex items-center gap-1">
                    {
                        navLinks.map((link) => (
                            <a
                                href={link.href}
                                class="px-4 py-2 text-sm font-medium text-muted-foreground hover:text-foreground hover:bg-white/10 rounded-full transition-all duration-300"
                            >
                                {link.label}
                            </a>
                        ))
                    }
                </nav>

                <div class="hidden md:block w-px h-6 bg-white/10"></div>

                <div class="flex items-center gap-3">
                    {
                        socialLinks.map((social) => (
                            <a
                                href={social.href}
                                target="_blank"
                                rel="noreferrer"
                                aria-label={social.label}
                                class={buttonVariants({
                                    variant: "ghost",
                                    size: "icon-sm",
                                    className: "rounded-full",
                                })}
                            >
                                <svg
                                    class="h-4 w-4"
                                    viewBox="0 0 24 24"
                                    fill="currentColor"
                                    aria-hidden="true"
                                >
                                    <Fragment set:html={social.icon} />
                                </svg>
                            </a>
                        ))
                    }
                    <a
                        href="https://t.me/ascp_marble"
                        target="_blank"
                        rel="noreferrer"
                        aria-label="Telegram"
                        class={buttonVariants({
                            variant: "ghost",
                            size: "icon-sm",
                            className: "rounded-full",
                        })}
                    >
                        <svg
                            class="h-4 w-4"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                        >
                            <path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z" />
                            <path d="m21.854 2.147-10.94 10.939" />
                        </svg>
                    </a>
                </div>
            </div>

            <div class="h-px w-full max-w-md bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

            <div class="flex flex-col items-center gap-2 text-center">
                <p class="text-sm text-muted-foreground">© 2025 ASCP. All Rights Reserved.</p>
                <p class="text-xs text-muted-foreground/60">
                    Designed by{" "}
                    <a
                        href="https://github.com/Drenzzz"
                        target="_blank"
                        rel="noreferrer"
                        class="font-medium text-primary/80 hover:text-primary transition-colors"
                    >
                        Drenzzz
                    </a>
                </p>
            </div>
        </div>
    </div>
</footer>
