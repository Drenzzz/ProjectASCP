---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/common/PageHeader.astro";
import { DeviceList } from "@/components/devices/DeviceList";
import { getAllDevices } from "@/lib/api/devices";
import Blob from "@/components/common/Blob.astro";

const devices = await getAllDevices();
const initialQuery = Astro.url.searchParams.get("q") ?? "";
const initialBrand = Astro.url.searchParams.get("brand") ?? "All";
---

<BaseLayout
    title="Devices | ASCP"
    description="Browse all supported devices for ASCP ROM"
>
    <div class="relative overflow-hidden">
        <Blob class="-top-20 -right-20" size="w-80 h-80" opacity={0.06} duration={50} />
        <Blob class="top-[35%] -left-20" size="w-72 h-72" opacity={0.05} duration={60} reverse={true} />

        <PageHeader
            title="Supported Devices"
            description="Browse all supported devices and download the latest builds."
            class="border-b-0"
        />

        <section class="container-wide pb-16 relative z-10">
            <DeviceList
                client:load
                initialDevices={devices}
                initialQuery={initialQuery}
                initialBrand={initialBrand}
            />
        </section>
    </div>
</BaseLayout>

