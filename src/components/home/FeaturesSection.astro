---
import SquiggleUnderline from "@/components/common/SquiggleUnderline.astro";

const features = [
    {
        title: "AOSP Based",
        description: "Built on Android Open Source Project with Pixel goodies. Close to stock, no unnecessary changes.",
        iconPath: `<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"></path><path d="m6.08 9.72-5.35 2.43a1 1 0 0 0-.58.91v5a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 18.06v-5a1 1 0 0 0-.58-.91l-5.35-2.43"></path>`,
        accent: false,
    },
    {
        title: "Fast & Smooth",
        description: "Kernel level optimisations and a tuned scheduler keep animations fluid, latency low, and thermals under control.",
        iconPath: `<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 12 14z"></path>`,
        accent: false,
    },
    {
        title: "Privacy First",
        description: "Additional privacy toggles and security patches merged within 24 hours of upstream release.",
        iconPath: `<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>`,
        accent: false,
    },
    {
        title: "Clean UI",
        description: "Material You design language with useful customizations. No bloatware, no gimmicks.",
        iconPath: `<path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.375 2.625a1 1 0 0 1 3 3l-9.013 9.014a2 2 0 0 1-.853.505l-2.873.84a.5.5 0 0 1-.62-.62l.84-2.873a2 2 0 0 1 .506-.852z"></path>`,
        accent: false,
    },
];
---

<section class="py-24 bg-gray-50 border-y border-gray-200">
    <div class="container-wide space-y-14">

        <!-- Section header -->
        <div class="text-center space-y-3 max-w-2xl mx-auto" data-reveal>
            <p class="text-xs font-semibold tracking-widest uppercase text-gray-400">Why ASCP</p>
            <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-gray-900">
                Why Choose <SquiggleUnderline>ASCP?</SquiggleUnderline>
            </h2>
            <p class="text-base md:text-lg text-gray-500 leading-relaxed">
                Built for users who care about performance, privacy, and a clean experience.
            </p>
        </div>

        <!-- 2x2 uniform grid — items-stretch keeps all cards same height per row -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 items-stretch" data-reveal-stagger="0.1">
            {features.map((feature) => (
                <div
                    class:list={[
                        "flex flex-col rounded-2xl border p-6 transition-shadow duration-200 hover:shadow-md",
                        feature.accent
                            ? "bg-primary/8 border-primary/20"
                            : "bg-white border-gray-200",
                    ]}
                    data-reveal-child
                >
                    <!-- Icon -->
                    <div class:list={[
                        "mb-4 w-10 h-10 flex items-center justify-center rounded-xl shrink-0",
                        feature.accent ? "bg-primary/15" : "bg-primary/10",
                    ]}>
                        <svg
                            class="h-5 w-5 text-primary"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                        >
                            <Fragment set:html={feature.iconPath} />
                        </svg>
                    </div>

                    <!-- Text — stacked vertically, not side-by-side -->
                    <div class="space-y-1.5">
                        <h3 class:list={[
                            "text-base font-semibold tracking-tight",
                            feature.accent ? "text-primary" : "text-gray-900",
                        ]}>
                            {feature.title}
                        </h3>
                        <p class="text-sm text-gray-500 leading-relaxed">
                            {feature.description}
                        </p>
                    </div>
                </div>
            ))}
        </div>

    </div>
</section>
