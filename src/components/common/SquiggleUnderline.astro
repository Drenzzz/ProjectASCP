---
/**
 * Squiggly underline doodle accent for headings.
 * DESIGN.md §8 — primary/20, aria-hidden.
 * Wrap your heading text, the squiggle sits below it.
 */
interface Props {
  class?: string;
  color?: string; // tailwind text color class
}

const {
  class: className = "",
  color = "text-primary/25",
} = Astro.props;
---

<span class:list={["relative inline-block", className]}>
  <slot />
  <svg
    class:list={["absolute -bottom-1.5 left-0 w-full h-[10px]", color]}
    viewBox="0 0 100 10"
    preserveAspectRatio="none"
    aria-hidden="true"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      d="M0 5 Q8 1 16 5 T32 5 T48 5 T64 5 T80 5 T96 5 T100 5"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </svg>
</span>
