---
import { marked } from "marked";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { DeviceTabs } from "@/components/device-detail/DeviceTabs";
import { CopyButton } from "@/components/common/CopyButton";
import { getDeviceByCodename } from "@/lib/api/devices";
import { getDeviceInstructions } from "@/lib/api/instructions";
import { getDeviceChangelog } from "@/lib/api/changelog";
import { getDeviceDownloadCount } from "@/lib/api/download-stats";
import { codenameSchema } from "@/lib/validators";
import { API_BASE } from "@/lib/api/client";

export async function getStaticPaths() {
    const { getAllDevices } = await import("@/lib/api/devices");
    const devices = await getAllDevices();
    return devices.map((d) => ({
        params: { codename: d.codename },
    }));
}

const { codename } = Astro.params;
const validation = codenameSchema.safeParse(codename);
if (!validation.success) {
    return Astro.redirect("/404");
}

const device = await getDeviceByCodename(validation.data);
if (!device) {
    return Astro.redirect("/404");
}

const [instructionsRaw, changelogRaw, downloadCount] = await Promise.all([
    getDeviceInstructions(validation.data),
    getDeviceChangelog(validation.data),
    getDeviceDownloadCount(validation.data),
]);

const instructionsHtml = instructionsRaw ? await marked.parse(instructionsRaw) : "";
const changelogHtml = changelogRaw ? await marked.parse(changelogRaw) : "";

const latestBuild = device.latestBuild;
const version = latestBuild?.version;
const buildDate = latestBuild?.builtDate;
const fileSize = latestBuild?.sizeFormatted;
const filename = latestBuild?.filename;
const md5 = latestBuild?.md5;

// Format exact download count without abbreviations
const formattedDownloadCount = new Intl.NumberFormat("en-US").format(downloadCount);

// Date formatting helper: transforms YYYY-MM-DD into "Month Day, Year"
function formatBuildDate(dateStr?: string) {
    if (!dateStr || dateStr === "Unknown") return "Unknown";
    try {
        const date = new Date(dateStr);
        if (isNaN(date.getTime())) return dateStr;
        return date.toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric",
        });
    } catch {
        return dateStr;
    }
}

const bannerUrl = `${API_BASE}/device/${device.codename}/banner/image.png`;
const displayImage = device.imageUrl || bannerUrl;
---

<BaseLayout
    title={`Download ASCP for ${device.name} (${device.codename})`}
    description={`Get the latest clean Android experience for ${device.name}. Maintained by ${device.maintainer}.`}
>
    <div class="container px-4 mx-auto py-12 max-w-7xl">
        <!-- M3E Bento Grid (4 Columns Layout on large screens) -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
            <!-- Card 1: Device Header Card (Col span 4) -->
            <div class="bento-card lg:col-span-4 md:col-span-2 col-span-1 p-8 md:p-10 rounded-[32px] bg-[#f0f4f8] border-0 shadow-none flex flex-col justify-between gap-8 hover:scale-[1.01] hover:bg-[#e4ebf3] transition-all duration-300">
                <div class="space-y-4">
                    <h1 class="text-5xl sm:text-6xl font-black text-gray-900 tracking-tight leading-tight">
                        {device.name}
                    </h1>
                </div>

                <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 pt-4 border-t border-gray-200/50">
                    <!-- Maintainer Info -->
                    <div class="flex items-center gap-3">
                        <img
                            src={device.maintainerAvatar}
                            alt={device.maintainer}
                            onerror="this.src='https://api.dicebear.com/7.x/initials/svg?seed=M'"
                            class="w-12 h-12 rounded-full bg-gray-200 object-cover shrink-0 select-none"
                            loading="lazy"
                        />
                        <div>
                            <p class="text-xs text-gray-400 font-extrabold tracking-wider mb-1">
                                Maintained by
                            </p>
                            <a
                                href={`https://github.com/${device.githubUsername || device.maintainer}`}
                                target="_blank"
                                rel="noreferrer"
                                class="text-lg font-extrabold text-gray-900 hover:text-primary transition-colors flex items-center gap-1 leading-none"
                            >
                                {device.maintainer}
                                <svg
                                    class="h-3.5 w-3.5 opacity-55"
                                    viewBox="0 0 24 24"
                                    fill="currentColor"
                                    aria-hidden="true"
                                >
                                    <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.74 4.042-1.61 4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path>
                                </svg>
                            </a>
                        </div>
                    </div>

                    <!-- Codename Pill (Repositioned, styled like download button, no uppercase) -->
                    <div class="flex items-center sm:self-end">
                        <span class="px-4 py-2.5 text-xxs font-extrabold bg-primary text-white tracking-wider rounded-full select-none shadow-xs border-0">
                            {device.codename}
                        </span>
                    </div>
                </div>
            </div>

            <!-- Card 2: Device Image Card (Col span 2, Row span 2) -->
            <div class="bento-card lg:col-span-2 lg:row-span-2 md:col-span-2 col-span-1 p-8 rounded-[32px] bg-[#f0f4f8] flex items-center justify-center min-h-[320px] lg:min-h-[440px] border-0 shadow-none relative overflow-hidden hover:scale-[1.01] hover:bg-[#e4ebf3] transition-all duration-300">
                {displayImage ? (
                    <img
                        src={displayImage}
                        alt={device.name}
                        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                        class="max-h-[220px] lg:max-h-[280px] w-auto object-contain drop-shadow-[0_12px_24px_rgba(0,0,0,0.12)] z-10 select-none transition-transform duration-500 hover:scale-105"
                    />
                    <div style="display:none;" class="flex flex-col items-center justify-center gap-3 text-gray-400 select-none z-10">
                        <svg class="w-12 h-12 stroke-[1.5]" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                            <circle cx="8.5" cy="8.5" r="1.5"></circle>
                            <polyline points="21 15 16 10 5 21"></polyline>
                        </svg>
                        <span class="text-[10px] font-extrabold tracking-widest text-gray-400">No Preview</span>
                    </div>
                ) : (
                    <div class="flex flex-col items-center justify-center gap-3 text-gray-400 select-none z-10">
                        <svg class="w-12 h-12 stroke-[1.5]" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                            <circle cx="8.5" cy="8.5" r="1.5"></circle>
                            <polyline points="21 15 16 10 5 21"></polyline>
                        </svg>
                        <span class="text-[10px] font-extrabold tracking-widest text-gray-400">No Preview</span>
                    </div>
                )}
            </div>

            <!-- Card 3: Download & Stats Card (Col span 2) -->
            <div class="bento-card lg:col-span-2 md:col-span-2 col-span-1 p-6 md:p-8 rounded-[32px] bg-[#f0f4f8] border-0 shadow-none flex flex-col justify-between gap-6 hover:scale-[1.01] hover:bg-[#e4ebf3] transition-all duration-300">
                <div>
                    <span class="text-sm font-extrabold text-gray-500 tracking-wider block mb-1.5">
                        Total Downloads
                    </span>
                    <span class="text-5xl font-black text-gray-900 tracking-tight block">
                        {formattedDownloadCount}
                    </span>
                </div>

                <a
                    href={latestBuild?.downloadUrl ?? "#"}
                    target="_blank"
                    rel="noreferrer"
                    class="w-full h-14 rounded-full bg-primary text-white font-bold hover:bg-primary/95 transition-all shadow-none hover:shadow-xs flex items-center justify-center gap-2 select-none cursor-pointer"
                >
                    <svg
                        class="h-5 w-5"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path d="M12 15V3"></path>
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <path d="m7 10 5 5 5-5"></path>
                    </svg>
                    Download Build
                </a>
            </div>

            <!-- Card 4: Status Card (Col span 1) -->
            <div class="bento-card lg:col-span-1 md:col-span-1 col-span-1 p-6 md:p-8 rounded-[32px] bg-[#f0f4f8] border-0 shadow-none flex flex-col justify-between hover:scale-[1.01] hover:bg-[#e4ebf3] transition-all duration-300">
                <span class="text-3xl font-extrabold text-gray-500 tracking-wider block mb-1.5">
                    Status
                </span>
                <div class="mt-auto">
                    {
                        device.active ? (
                            <span class="inline-flex items-center justify-center gap-2 h-10 w-full rounded-full text-md font-extrabold bg-emerald-600 text-white select-none shadow-xs border-0">
                                Active
                            </span>
                        ) : (
                            <span class="inline-flex items-center justify-center gap-2 h-10 w-full rounded-full text-md font-extrabold bg-gray-250 text-gray-500 select-none border-0">
                                Discontinued
                            </span>
                        )
                    }
                </div>
            </div>

            <!-- Card 5: File Size Card (Col span 1) -->
            <div class="bento-card lg:col-span-1 md:col-span-1 col-span-1 p-6 md:p-8 rounded-[32px] bg-[#f0f4f8] border-0 shadow-none flex flex-col justify-between hover:scale-[1.01] hover:bg-[#e4ebf3] transition-all duration-300">
                <span class="text-3xl font-extrabold text-gray-500 tracking-wider block mb-1.5">
                    File Size
                </span>
                <span class="text-5xl font-black text-gray-900 mt-auto leading-none">
                    {fileSize ?? "N/A"}
                </span>
            </div>

            <!-- Card 6: Latest Version Card (Col span 1) -->
            <div class="bento-card lg:col-span-1 md:col-span-1 col-span-1 p-6 md:p-8 rounded-[32px] bg-[#f0f4f8] border-0 shadow-none flex flex-col justify-between hover:scale-[1.01] hover:bg-[#e4ebf3] transition-all duration-300">
                <span class="text-md font-extrabold text-gray-500 tracking-wider block mb-1.5">
                    Latest Version
                </span>
                <span class:list={[
                    "font-black text-gray-900 mt-auto leading-none",
                    version ? "text-8xl" : "text-4xl pb-2"
                ]}>
                    {version ?? "Unknown"}
                </span>
            </div>

            <!-- Card 7: Build Date Card (Col span 1) -->
            <div class="bento-card lg:col-span-1 md:col-span-1 col-span-1 p-6 md:p-8 rounded-[32px] bg-[#f0f4f8] border-0 shadow-none flex flex-col justify-between hover:scale-[1.01] hover:bg-[#e4ebf3] transition-all duration-300">
                <span class="text-md font-extrabold text-gray-500 tracking-wider block mb-1.5">
                    Build Date
                </span>
                <span class="text-4xl font-black text-gray-900 mt-auto leading-tight pt-2">
                    {formatBuildDate(buildDate)}
                </span>
            </div>

            <!-- Card 8: Filename & Checksum Card (Col span 2) -->
            <div class="bento-card lg:col-span-2 md:col-span-2 col-span-1 p-6 md:p-8 rounded-[32px] bg-[#f0f4f8] border-0 shadow-none flex flex-col justify-between gap-4 hover:scale-[1.01] hover:bg-[#e4ebf3] transition-all duration-300">
                <div>
                    <span class="text-sm font-extrabold text-gray-500 tracking-wider block mb-1.5">
                        Filename
                    </span>
                    <span class="text-sm font-bold text-gray-700 break-all select-all block leading-relaxed">
                        {filename ?? "Unknown"}
                    </span>
                </div>

                <div>
                    <span class="text-sm font-extrabold text-gray-500 tracking-wider block mb-2">
                        MD5 Checksum
                    </span>
                    <div class="flex items-center justify-between gap-3 bg-white px-4 py-2 rounded-2xl border-0">
                        <code class="text-xs font-mono text-gray-600 truncate select-all">{md5 ?? "Not Available"}</code>
                        {md5 && <CopyButton client:load value={md5} />}
                    </div>
                </div>
            </div>

            <!-- Card 9: Documentation / Tabs Card (Col span 4) -->
            <div class="bento-card lg:col-span-4 md:col-span-2 col-span-1 pt-6">
                <DeviceTabs
                    client:load
                    instructionsHtml={instructionsHtml}
                    changelogHtml={changelogHtml}
                />
            </div>
            
        </div>
    </div>

    <!-- Lenis & GSAP Animation Script -->
    <script>
        import Lenis from "lenis";
        import { gsap } from "gsap";

        // Initialize Lenis smooth scroll
        const lenis = new Lenis();
        function raf(time: number) {
            lenis.raf(time);
            requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        // Stagger fade-in for Bento Grid cards using fromTo for absolute stability
        gsap.fromTo(
            ".bento-card",
            { opacity: 0, y: 16 },
            {
                opacity: 1,
                y: 0,
                duration: 0.6,
                stagger: 0.05,
                ease: "power2.out",
                clearProps: "transform",
            }
        );
    </script>

    <!-- CSS stylesheet block to prevent FOUC (Flash of Unstyled Content) -->
    <style>
        .bento-card {
            opacity: 0;
            transform: translateY(16px);
        }
    </style>
</BaseLayout>
