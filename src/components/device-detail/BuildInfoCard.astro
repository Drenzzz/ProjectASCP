---
export interface Props {
    version?: string;
    buildDate?: string;
    fileSize?: string;
    filename?: string;
}

const { version, buildDate, fileSize, filename } = Astro.props;

interface StatItem {
    label: string;
    value: string;
    size: "lg" | "md" | "sm";
}

const items: StatItem[] = [
    { label: "Latest Version", value: version ?? "1.0", size: "lg" },
    { label: "Build Date", value: buildDate ?? "Unknown", size: "md" },
    { label: "File Size", value: fileSize ?? "N/A", size: "lg" },
    { label: "Filename", value: filename ?? "ascp-build-release.zip", size: "sm" },
];
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    {
        items.map((item) => (
            <div class="p-6 rounded-3xl bg-secondary/10 border border-white/5 backdrop-blur-sm flex flex-col justify-between group hover:border-primary/20 transition-colors">
                <p class="text-sm text-muted-foreground font-mono mb-2">{item.label}</p>
                <p
                    class:list={[
                        "mt-auto",
                        item.size === "lg" && "text-3xl font-bold tracking-tight text-foreground",
                        item.size === "md" && "font-mono text-xl text-foreground/90 font-bold",
                        item.size === "sm" && "font-mono text-xs break-all text-white/70 line-clamp-3 leading-relaxed",
                    ]}
                >
                    {item.value}
                </p>
            </div>
        ))
    }
</div>
