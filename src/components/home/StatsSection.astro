---
import { getAllDevices } from "@/lib/api/devices";
import { getDownloadsCount } from "@/lib/api/stats";

const downloads = await getDownloadsCount();
const devices = await getAllDevices();

const stats = [
    {
        label: "Downloads",
        // numeric target for count-up, suffix separate
        target: downloads,
        suffix: "+",
        decimals: 0,
    },
    {
        label: "Supported Devices",
        target: devices.length || 22,
        suffix: "",
        decimals: 0,
    },
    {
        label: "Community Members",
        target: 2.5,
        suffix: "K+",
        decimals: 1,
    },
];
---

<section class="py-16 border-b border-gray-200" data-reveal>
    <div class="container-wide">
        <div class="bg-primary rounded-3xl px-8 py-14">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12 divide-y md:divide-y-0 md:divide-x divide-white/20">
                {stats.map((stat) => (
                    <div class="text-center space-y-2 pt-8 md:pt-0 first:pt-0">
                        <h3
                            class="text-5xl md:text-6xl font-extrabold tracking-tight text-white tabular-nums"
                            data-count-target={stat.target}
                            data-count-suffix={stat.suffix}
                            data-count-decimals={stat.decimals}
                        >
                            {stat.decimals > 0
                                ? stat.target.toFixed(stat.decimals)
                                : new Intl.NumberFormat("en-US").format(Math.floor(stat.target))
                            }{stat.suffix}
                        </h3>
                        <p class="text-xs font-semibold tracking-widest uppercase text-white/60">
                            {stat.label}
                        </p>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>
