---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PhilosophyCard from "@/components/about/PhilosophyCard.astro";
import TeamSection from "@/components/about/TeamSection.astro";

const philosophyItems = [
    {
        iconPath: `<path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"></path><path d="M9 18h6"></path><path d="M10 22h4"></path>`,
        title: "Our Philosophy",
        description:
            "We believe in minimalism. Modern custom ROMs are often bloated with features that slow down the device. ASCP strips away the noise and focuses on what matters: battery life, smoothness, and security.",
    },
    {
        iconPath: `<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path><path d="m9 12 2 2 4-4"></path>`,
        title: "Quality First",
        description:
            "Every build goes through rigorous testing before release. We prioritize stability and performance over feature bloat, ensuring your device runs exactly as intended.",
    },
];
---

<BaseLayout
    title="About | ASCP"
    description="Learn more about the ASCP Project and the team behind it."
>
    <div class="container mx-auto px-4 pt-28 pb-16 max-w-7xl space-y-12">
        
        {/* Row 1: Header Card */}
        <div class="bento-card w-full p-10 md:p-12 rounded-[32px] bg-[#f0f4f8] hover:bg-[#e4ebf3] hover:scale-[1.005] transition-all duration-300 flex flex-col md:flex-row items-center justify-between gap-8 border-0 shadow-none relative overflow-hidden">
            <div class="space-y-4 max-w-2xl">
                <span class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-extrabold bg-primary text-white tracking-wider select-none border-0">
                    Project Overview
                </span>
                <h1 class="text-5xl md:text-6xl font-black text-gray-900 tracking-tight leading-none">
                    About <span class="text-primary font-black">ASCP</span>
                </h1>
                <p class="text-lg text-gray-600 leading-relaxed font-medium">
                    The Project ASCP aims to provide a clean, performant, and stable Android
                    experience close to AOSP but with essential enhancements that power
                    users actually need.
                </p>
            </div>
            <div class="shrink-0 select-none bg-transparent">
                <img src="/logo/ASCP.png" alt="ASCP Logo" class="w-48 h-48 md:w-44 md:h-44 rounded-[28px] object-cover animate-pulse" />
            </div>
        </div>

        {/* Row 2: Philosophy Cards (2 Column Grid) */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full items-stretch">
            {
                philosophyItems.map((item) => (
                    <PhilosophyCard
                        iconPath={item.iconPath}
                        title={item.title}
                        description={item.description}
                    />
                ))
            }
        </div>

        {/* Row 3: Team Header Section */}
        <div class="text-center space-y-3 pt-6">
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-extrabold bg-primary text-white tracking-wider uppercase select-none border-0">
                Our Contributors
            </span>
            <h2 class="text-4xl font-black text-gray-900 tracking-tight">Meet the Team</h2>
            <p class="text-base text-gray-500 font-bold">The minds behind the project</p>
        </div>

        {/* Row 4: Team Grid */}
        <div class="w-full">
            <TeamSection />
        </div>
    </div>

    <script>
        import { gsap } from "gsap";

        gsap.fromTo(
            ".bento-card",
            { opacity: 0, y: 16 },
            {
                opacity: 1,
                y: 0,
                duration: 0.6,
                stagger: 0.05,
                ease: "power2.out",
                clearProps: "transform",
            }
        );
    </script>

    <!-- CSS stylesheet block to prevent FOUC (Flash of Unstyled Content) -->
    <style>
        .bento-card {
            opacity: 0;
            transform: translateY(16px);
        }
    </style>
</BaseLayout>
