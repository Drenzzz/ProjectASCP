---
import { CopyButton } from "@/components/common/CopyButton";

export interface Props {
    md5?: string;
}

const { md5 } = Astro.props;
const isAvailable = Boolean(md5);
---

<div class="md:col-span-2 lg:col-span-4 p-5 rounded-3xl bg-secondary/5 border border-white/5 backdrop-blur-sm flex items-center justify-between gap-4 overflow-hidden">
    <div class="flex items-center gap-4 min-w-0">
        <div class="h-10 w-10 rounded-xl bg-white/5 flex items-center justify-center shrink-0 text-muted-foreground">
            <span class="font-mono text-xs font-bold">MD5</span>
        </div>
        <code class="text-sm font-mono text-muted-foreground truncate select-all">{md5 ?? "Not Available"}</code>
    </div>
    {isAvailable && md5 && <CopyButton value={md5} />}
</div>
