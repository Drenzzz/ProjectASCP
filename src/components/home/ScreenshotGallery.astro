---
const screenshots = Array.from({ length: 37 }, (_, i) => ({
    src: `/screenshots/ss${i + 1}.jpg`,
    id: i + 1,
}));
---

<div class="container mx-auto px-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {
            screenshots.map((screenshot) => (
                <a
                    href={screenshot.src}
                    target="_blank"
                    rel="noreferrer"
                    class="group block overflow-hidden rounded-xl border border-white/5 bg-white/[0.02] transition-all duration-300 hover:border-primary/40 hover:shadow-[0_0_30px_-10px] hover:shadow-primary/20"
                    aria-label={`Open screenshot ${screenshot.id} in new tab`}
                >
                    <div class="aspect-[9/16] overflow-hidden bg-black/40">
                        <img
                            src={screenshot.src}
                            alt={`ASCP screenshot ${screenshot.id}`}
                            width="360"
                            height="640"
                            loading="lazy"
                            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                        />
                    </div>
                </a>
            ))
        }
    </div>
</div>
